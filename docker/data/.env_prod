ENV_NAME="prod"

# PostgreSQL
POSTGRES_USER=proxymanager
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password
POSTGRES_DB=proxymanager

# Application
DATABASE_URL=postgresql+asyncpg://proxymanager:CHANGE_ME_use_a_strong_random_password@db:5432/proxymanager
DATABASE_URL_SYNC=postgresql+psycopg2://proxymanager:CHANGE_ME_use_a_strong_random_password@db:5432/proxymanager

# Port
PM_PORT=8222

# JWT
PM_SECRET_KEY=CHANGE_ME_use_a_long_random_string
