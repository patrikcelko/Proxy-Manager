ENV_NAME=local

# PostgreSQL
POSTGRES_USER=proxymanager
POSTGRES_PASSWORD=proxymanager
POSTGRES_DB=proxymanager

# Application
DATABASE_URL=postgresql+asyncpg://proxymanager:proxymanager@db:5432/proxymanager
DATABASE_URL_SYNC=postgresql+psycopg2://proxymanager:proxymanager@db:5432/proxymanager

# Port
PM_PORT=8222

# JWT
PM_SECRET_KEY=local-dev-secret-not-for-production
